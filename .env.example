# Firebase configuration
# Copy this file to config.local.js and fill in your values
# NEVER commit config.local.js to version control

FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Anthropic API Key (used for receipt scanning)
# WARNING: See SECURITY.md — this key is stored client-side only
ANTHROPIC_API_KEY=your_anthropic_key_here
